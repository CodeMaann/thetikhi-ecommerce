# OWNER_EMAIL: The email address that should receive new-order alerts.
OWNER_EMAIL="thetikhi.com@gmail.com"

# Shiprocket Configuration
# SHIPROCKET_EMAIL/PASSWORD are the client's Shiprocket seller panel login.
# Used to generate an API auth token, NOT a fixed API key.
SHIPROCKET_EMAIL="your_shiprocket_email"
SHIPROCKET_PASSWORD="your_shiprocket_password"
# SHIPROCKET_PICKUP_LOCATION is the pickup address nickname configured in Shiprocket panel
SHIPROCKET_PICKUP_LOCATION="Primary"
# SHIPROCKET_WEBHOOK_TOKEN is a secret string used to verify incoming webhook requests
SHIPROCKET_WEBHOOK_TOKEN="your_webhook_secret_token"
